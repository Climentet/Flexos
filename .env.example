# For production on Render: Use Supabase POOLER URL, NOT direct connection
# Go to Supabase → Settings → Database → Connection Pooling → Session mode
# Copy the URL that starts with: postgresql://postgres.PROJECT_REF...@...pooler.supabase.com:6543
DATABASE_URL=postgresql://postgres:[Makrichonda69]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
SESSION_SECRET=change_me

# Challenge password for login
CHALLENGE_PASSWORD=Makrichonda

# Environment
NODE_ENV=production
